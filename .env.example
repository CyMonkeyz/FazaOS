# FazaOS environment template.
# Copy this file to .env and replace placeholders. Never commit real .env files.

# Supabase browser + server
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key

# DeepSeek AI, server-only
DEEPSEEK_API_KEY=your-deepseek-api-key
# Optional override. Current default in code: deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional web search for Sora live/realtime answers.
# Use one provider; Sora falls back to a lightweight no-key search if all are empty.
TAVILY_API_KEY=
# Optional alias if you typed it as "talify" in your env.
TALIFY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# Telegram bot, server-only
TELEGRAM_API_KEY=your-telegram-bot-token
# Required separate cron secret. Do not reuse Supabase publishable/anon keys.
CRON_SECRET=generate-a-long-random-cron-secret

# Google OAuth, server-only. Refresh token must include Calendar, Drive, and Sheets scopes.
# Required scopes: calendar, drive, spreadsheets.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_ID=primary


# Investment price updates, server-only and optional
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
MARKET_DATA_API_KEY=
